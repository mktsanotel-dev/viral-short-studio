# ============================================================
#   VIRAL SHORT STUDIO — CẤU HÌNH (tùy chọn)
#   Cách dùng: COPY file này thành  .env  rồi điền giá trị của BẠN.
#   Bỏ trống dòng nào cũng được — phần mềm vẫn chạy bình thường.
# ============================================================

# ---- THƯƠNG HIỆU CỦA BẠN (hiện trên thumbnail + định hướng AI) ----
# Tên hiển thị trên bìa/thumbnail. Trống = không in tên.
VSS_BRAND_NAME=
# Chủ đề/lĩnh vực kênh — giúp AI chọn đúng đoạn "đắt" của bạn.
VSS_BRAND_NICHE=phát triển bản thân & kinh doanh
# Màu nhấn thương hiệu (mã màu hex).
VSS_BRAND_COLOR=#d3102e
# Chữ phụ nhỏ ở góc header.
VSS_BRAND_SYSTEM=Viral Short Studio
# (Nâng cao) Thư mục ảnh chân dung để dựng "bìa thương hiệu". Trống = bỏ qua bìa.
VSS_THUMB_DIR=

# ---- CỔNG CHẠY (đổi nếu 5178 bị trùng) ----
VSS_PORT=5178

# ---- ĐƯỜNG DẪN CÔNG CỤ (thường KHÔNG cần điền — để trống) ----
# Chỉ điền nếu máy không tự tìm thấy. Mac dùng .venv được launcher tự set.
# VSS_PYTHON=
# VSS_YTDLP=
# VSS_FFMPEG=ffmpeg
# VSS_FFPROBE=ffprobe
# VSS_CHROME=
# VSS_CLAUDE=claude

# ============================================================
#   (NÂNG CAO) TỰ ĐĂNG LÊN LARK BASE — chỉ điền nếu bạn dùng Lark
#   Không điền = tính năng "đăng Lark" tắt, mọi thứ khác vẫn chạy.
#
#   💡 DỄ HƠN: mở phần mềm → tab "⚙️ Cấu hình" → dán link Base →
#      "Dò bảng & cột" → chọn cột → Lưu. Không cần đụng file này.
#      (Cấu hình từ giao diện lưu ở settings.local.json và ĐÈ LÊN các dòng dưới.)
# ============================================================
# VSS_LARK_BASE=            # token của Base (bảng) của BẠN
# VSS_LARK_TABLE=           # id bảng
# VSS_LARK_ATTACH_FIELD=    # id cột đính kèm video
# VSS_LARK_THUMB_FIELD=     # id cột ảnh bìa
# VSS_LARK_CONTENT_FIELD=Nội dung
# VSS_LARK_TYPE_FIELD=Loại
# VSS_LARK_TYPE_VALUE=Video
# VSS_LARK_FANPAGE_FIELD=Fanpage
# VSS_LARK_FANPAGE_REC=     # id record fanpage
# VSS_LARK_JS=              # đường dẫn run.js của @larksuite/cli (nếu tự dò không ra)
